{
  "name": "nestjs-metrics",
  "version": "0.2.1",
  "description": "Generate metrics and trends data from your TypeORM entities for your dashboards.",
  "keywords": [
    "nestjs",
    "typeorm",
    "metrics",
    "trends",
    "charts",
    "dashboard",
    "analytics"
  ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/nestjs-metrics.git"
  },
  "homepage": "https://github.com/PedroPCardoso/nestjs-metrics#readme",
  "bugs": {
    "url": "https://github.com/PedroPCardoso/nestjs-metrics/issues"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./nestjs": {
      "require": "./dist/nestjs/index.js",
      "types": "./dist/nestjs/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "nestjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "smoke": "bash scripts/consumer-smoke.sh",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "typeorm": "^0.3"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "dependencies": {
    "luxon": "^3"
  },
  "devDependencies": {
    "@changesets/cli": "^2",
    "@nestjs/common": "^10",
    "@nestjs/core": "^10",
    "@nestjs/testing": "^10",
    "@types/luxon": "^3",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "better-sqlite3": "^11",
    "eslint": "^8",
    "mysql2": "^3",
    "pg": "^8",
    "reflect-metadata": "^0.2",
    "tsup": "^8",
    "typeorm": "^0.3",
    "typescript": "^5",
    "vitest": "^2"
  },
  "sideEffects": false
}
