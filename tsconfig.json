{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "nestjs-metrics-core": ["packages/core/src/index.ts"],
      "nestjs-metrics-core/*": ["packages/core/src/*"],
      "nestjs-metrics": ["packages/nestjs-metrics/src/index.ts"],
      "nestjs-metrics/nestjs": ["packages/nestjs-metrics/src/nestjs/index.ts"],
      "nextjs-metrics": ["packages/nextjs-metrics/src/index.ts"],
      "@core/*": ["packages/core/src/*"]
    }
  },
  "include": ["packages/*/src", "test"],
  "exclude": ["node_modules", "**/dist"]
}
