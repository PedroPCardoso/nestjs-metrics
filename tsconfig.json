{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pedropcardoso/metrics-core": ["packages/core/src/index.ts"],
      "@pedropcardoso/metrics-core/*": ["packages/core/src/*"],
      "@pedropcardoso/metrics-nestjs": ["packages/nestjs/src/index.ts"],
      "@pedropcardoso/metrics-nextjs": ["packages/nextjs/src/index.ts"],
      "@pedropcardoso/metrics-nextjs/prisma": ["packages/nextjs/src/prisma/index.ts"],
      "@pedropcardoso/metrics-nextjs/drizzle": ["packages/nextjs/src/drizzle/index.ts"],
      "@core/*": ["packages/core/src/*"]
    }
  },
  "include": ["packages/*/src", "test"],
  "exclude": ["node_modules", "**/dist"]
}
