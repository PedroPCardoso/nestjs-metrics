{
  "name": "nestjs-metrics",
  "version": "0.2.3",
  "description": "Generate metrics and trends data from your TypeORM entities for your dashboards. (Façade over @pedropcardoso/metrics-core + @pedropcardoso/metrics-nestjs.)",
  "keywords": [
    "nestjs",
    "typeorm",
    "metrics",
    "trends",
    "charts",
    "dashboard",
    "analytics"
  ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/nestjs-metrics.git",
    "directory": "packages/nestjs-metrics"
  },
  "homepage": "https://github.com/PedroPCardoso/nestjs-metrics#readme",
  "bugs": {
    "url": "https://github.com/PedroPCardoso/nestjs-metrics/issues"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./nestjs": {
      "require": "./dist/nestjs/index.js",
      "types": "./dist/nestjs/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "nestjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pedropcardoso/metrics-core": "^0.2.0",
    "@pedropcardoso/metrics-nestjs": "^0.2.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "typeorm": "^0.3"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  }
}
