{
  "name": "@metrics-kit/nestjs",
  "version": "0.2.0",
  "description": "NestJS module + service over @metrics-kit/core (TypeORM).",
  "keywords": [
    "nestjs",
    "typeorm",
    "metrics",
    "trends",
    "dashboard",
    "analytics"
  ],
  "author": "Pedro Cardoso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroPCardoso/nestjs-metrics.git",
    "directory": "packages/nestjs"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metrics-kit/core": "^0.2.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "typeorm": "^0.3"
  }
}
